RewriteEngine On

# 🔐 Security
Options -Indexes

# ===========================
# Exclude sitemap.php and index.php
# ===========================
RewriteCond %{REQUEST_URI} ^/(sitemap\.php|index\.php)$ [NC]
RewriteRule ^ - [L]

# Root → index.php
RewriteRule ^$ index.php [L]

# ===========================
# Sitemap
# ===========================
RewriteRule ^sitemap$ sitemap.php [L]

# ===========================
# Redirect /pages/*.php → clean
# ===========================
RewriteCond %{THE_REQUEST} \s/pages/(.+?)\.php[\s?] [NC]
RewriteRule ^pages/(.+?)\.php$ /$1 [R=301,L]

# ===========================
# Remove .php from URLs
# ===========================
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
RewriteCond %{REQUEST_URI} !^/pages/
RewriteCond %{REQUEST_URI} !^/sitemap\.php$ [NC]
RewriteCond %{REQUEST_URI} !^/index\.php$ [NC]
RewriteRule ^(.+)\.php$ /$1 [R=301,L]

# ===========================
# Page routes
# ===========================
RewriteRule ^about/?$ pages/about.php [L]
RewriteRule ^contact/?$ pages/contact.php [L]
RewriteRule ^careers/?$ pages/careers.php [L]
RewriteRule ^safety/?$ pages/safety.php [L]
RewriteRule ^fleet/?$ pages/fleet.php [L]
RewriteRule ^tracking/?$ pages/tracking.php [L]

# ===========================
# Service routes
# ===========================
RewriteRule ^services/flatbed/?$ pages/services/flatbed.php [L]
RewriteRule ^services/reefer/?$ pages/services/reefer.php [L]
RewriteRule ^services/stepdeck/?$ pages/services/stepdeck.php [L]
RewriteRule ^services/wideload/?$ pages/services/wideload.php [L]

# ===========================
# FORMS (🔥 FIX)
# ===========================
RewriteRule ^forms/([a-zA-Z0-9-]+)/?$ forms/$1.php [L]

# ===========================
# Fallback (excluding forms)
# ===========================
RewriteCond %{REQUEST_URI} !^/forms/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)$ pages/$1.php [L]